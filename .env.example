# Copy this file to .env and fill in the required values.

# Required: BotFather token for your private bot.
TELEGRAM_BOT_TOKEN=

# Required: your numeric Telegram user id (the only user allowed to use the bot).
OWNER_ID=

# Optional: default Claude model id (aliases handled in /model: opus/sonnet/haiku).
DEFAULT_MODEL=claude-opus-4-8

# Optional: base directory for per-thread code-mode working dirs (created if missing).
BASE_WORKDIR=./workdirs

# Optional: SQLite database file for per-thread state and usage.
DB_PATH=./bot.db

# IMPORTANT: do NOT set ANTHROPIC_API_KEY (or ANTHROPIC_AUTH_TOKEN).
# The Agent SDK spawns the claude CLI, which must use your logged-in
# Pro/Max SUBSCRIPTION credentials. Any ANTHROPIC_API_KEY present would
# force paid API billing instead of the subscription. Keep it UNSET.
# Log in once on the host with:  claude setup-token   (or interactive claude login)

# Optional: path to the JSON allowlist of permitted users. This file is
# gitignored and lists the users allowed to use the bot (the owner is always
# allowed regardless of its contents).
ALLOWLIST_PATH=./allowlist.json

# Optional: extra prompt keyword triggers to neutralize, ON TOP of the built-in
# defaults (ultrathink, ultracode). The bundled Claude CLI acts on these words when
# they appear in a user's message — `ultrathink` escalates reasoning effort,
# `ultracode` spins up multi-agent Workflow orchestration — which can burn the one
# shared subscription or bypass the per-user effort gate. The bot already disables
# Workflows and defuses the defaults; list MORE words here (comma- or
# space-separated) to render them inert too. Leave unset to use just the defaults.
# BLOCKED_PROMPT_KEYWORDS=

# Optional: per-code-session sandbox (#104). OFF by default. When 1/true, each
# code session's `claude` runs in a bubblewrap jail (unprivileged uid, confined to
# its session workdir, the subscription token injected read-only, env wiped).
# Requires the `bubblewrap` package installed. All OS interaction is in
# deploy/sandbox-claude.sh. SANDBOX_UID = the unprivileged uid the jail drops to.
# NOTE: still in development (#119) — the jail's network is open and the agent can
# read the injected token, so it limits filesystem blast radius for semi-trusted
# users, not a malicious one. Grant code access only to people you trust.
# SANDBOX_CODE=0
# SANDBOX_UID=65534
